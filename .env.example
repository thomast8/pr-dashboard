# GitHub PAT (fine-grained, org-scoped, read-only PRs/checks/reviews)
GITHUB_TOKEN=ghp_...
GITHUB_ORG=kyndryl-agentic-ai

# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pr_dashboard

# Sync interval (seconds between GitHub sync cycles)
SYNC_INTERVAL_SECONDS=180

# Auth (leave empty to disable password protection)
DASHBOARD_PASSWORD=
SECRET_KEY=change-me-in-production

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
