# Database (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pr_dashboard

# Sync interval (seconds between GitHub sync cycles)
SYNC_INTERVAL_SECONDS=180

# Auth (leave empty to disable password protection)
DASHBOARD_PASSWORD=
# Used for signing session cookies. Changing this invalidates all active sessions.
SECRET_KEY=change-me-in-production
# Optional: dedicated key for encrypting GitHub/ADO tokens at rest (Fernet).
# Falls back to SECRET_KEY if not set.
# WARNING: Changing this (or SECRET_KEY if this is unset) requires a server restart
# and makes all previously encrypted tokens unreadable. Users will need to re-link
# their accounts with fresh tokens.
#ENCRYPTION_KEY=

# GitHub OAuth App (register at github.com/settings/developers)
# Homepage URL: http://localhost:5173 (dev)
# Callback URL: http://localhost:8000/api/auth/github/callback (dev)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub Webhooks (optional, enables instant PR updates)
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=
# Public URL where GitHub sends webhook events (e.g. https://your-tunnel.trycloudflare.com)
WEBHOOK_BASE_URL=

# GitHub Enterprise domains (comma-separated, for SSRF protection on base_url)
# Example: github.mycompany.com,ghe.internal.io
#ALLOWED_GHE_DOMAINS=

# Dev mode (enables user impersonation at POST /api/auth/dev-login/{user_id})
DEV_MODE=false

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
